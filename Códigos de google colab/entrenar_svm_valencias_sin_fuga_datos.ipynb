import os
import re
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from google.colab import drive
from sklearn.model_selection import GroupShuffleSplit, RandomizedSearchCV
from sklearn.preprocessing import StandardScaler, LabelEncoder
from sklearn.svm import SVC
from sklearn.feature_selection import SelectKBest, f_classif
from sklearn.pipeline import Pipeline
from sklearn.inspection import permutation_importance
from sklearn.metrics import classification_report, accuracy_score, confusion_matrix

if not os.path.exists('/content/drive'):
    drive.mount('/content/drive')

RUTA_DATASET = '/content/drive/MyDrive/v8_aug.csv'
df = pd.read_csv(RUTA_DATASET)

mapa_grupos = {
    'Felicidad': 'Positivo', 'Sorpresa': 'Positivo',
    'Enfado': 'Negativo', 'Miedo': 'Negativo', 'Asco': 'Negativo', 'Tristeza': 'Negativo',
    'Neutral': 'Neutral'
}
df['emocion_agrupada'] = df['emocion'].map(mapa_grupos)
df = df.dropna(subset=['emocion_agrupada'])

columnas_validas = [col for col in df.columns if not col.startswith('delta_')]
df_limpio = df[columnas_validas]

df_limpio['id_audio_original'] = df_limpio['archivo'].apply(
    lambda nombre: re.sub(r'^(orig_|ruido_|fast_|slow_)', '', str(nombre))
)

X = df_limpio.drop(['archivo', 'emocion', 'emocion_agrupada', 'id_audio_original'], axis=1)
le = LabelEncoder()
y = le.fit_transform(df_limpio['emocion_agrupada'])
grupos = df_limpio['id_audio_original']

divisor = GroupShuffleSplit(n_splits=1, test_size=0.20, random_state=42)
idx_train, idx_test = next(divisor.split(X, y, groups=grupos))
X_train, X_test = X.iloc[idx_train], X.iloc[idx_test]
y_train, y_test = y[idx_train], y[idx_test]

grupos_train = set(grupos.iloc[idx_train])
grupos_test = set(grupos.iloc[idx_test])
solapamiento = grupos_train & grupos_test
print(f"\n Grupos solapados entre train y test: {len(solapamiento)}")

tuberia = Pipeline([
    ('scaler', StandardScaler()),
    ('selector', SelectKBest(f_classif)),
    ('svm', SVC(random_state=42, class_weight='balanced', probability=True))
])
parametros_dist = {
    'selector__k': [25, 28, 30, 31],
    'svm__C': [0.01, 0.05, 0.1, 0.5, 1, 5, 10],
    'svm__gamma': ['scale', 'auto', 0.001, 0.01, 0.1],
    'svm__kernel': ['rbf'],
    'svm__class_weight': [
        'balanced',
        {0: 1.0, 1: 2.0, 2: 1.5},
        {0: 1.0, 1: 2.2, 2: 1.6},
    ]
}
buscador = RandomizedSearchCV(
    tuberia, parametros_dist, n_iter=40, cv=10, n_jobs=-1, verbose=1, random_state=42
)
buscador.fit(X_train, y_train)
print(f"\nMejores hiperparámetros encontrados: {buscador.best_params_}")

mejor_modelo_val = buscador.best_estimator_
y_pred = mejor_modelo_val.predict(X_test)
exactitud = accuracy_score(y_test, y_pred) * 100
print(f"\nExactitud final (sin fuga de datos): {exactitud:.2f}%")
print(classification_report(y_test, y_pred, target_names=le.classes_))

plt.figure(figsize=(7, 5))
sns.heatmap(confusion_matrix(y_test, y_pred), annot=True, fmt='d', cmap='Blues',
            xticklabels=le.classes_, yticklabels=le.classes_)
plt.title(f'Matriz de Confusión - Valencias (Exactitud: {exactitud:.2f}%)')
plt.ylabel('Clase Real'); plt.xlabel('Clase Predicha')
plt.tight_layout(); plt.show()

r_val = permutation_importance(mejor_modelo_val, X_test, y_test, n_repeats=5, random_state=42)
indices_ordenados_val = r_val.importances_mean.argsort()[-20:]
plt.figure(figsize=(12, 8))
plt.barh(X.columns[indices_ordenados_val], r_val.importances_mean[indices_ordenados_val], color='royalblue')
plt.title('Top 20 Variables Clave en la Toma de Decisión (SVM)')
plt.grid(axis='x', linestyle='--', alpha=0.7)
plt.tight_layout(); plt.show()
