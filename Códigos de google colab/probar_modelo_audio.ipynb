import librosa
import librosa.display
import numpy as np
import pandas as pd
import joblib
import matplotlib.pyplot as plt
from google.colab import files

print("sube los archivos de tu modelo (.pkl) y del encoder (.pkl):")
subidos = files.upload()

archivos_en_sesion = list(subidos.keys())

try:
    modelo_file = [f for f in archivos_en_sesion if 'modelo' in f.lower() and f.endswith('.pkl')][0]
    encoder_file = [f for f in archivos_en_sesion if ('label' in f.lower() or 'encoder' in f.lower()) and f.endswith('.pkl')][0]

    modelo_ia = joblib.load(modelo_file)
    le = joblib.load(encoder_file)

    print(f"\nCargados correctamente:")
    print(f"   - Modelo Predictivo: {modelo_file}")
    print(f"   - Codificador de Etiquetas: {encoder_file}")

except IndexError:
    print("\n[ERROR]")

def examinar_audio(ruta):
    y, sr = librosa.load(ruta, sr=44100)
    y, _ = librosa.effects.trim(y, top_db=25)
    plt.figure(figsize=(12, 4))
    plt.subplot(1, 2, 1)
    librosa.display.waveshow(y, sr=sr)
    plt.title("Onda Real del Audio")
    
    plt.subplot(1, 2, 2)
    S = librosa.feature.melspectrogram(y=y, sr=sr)
    librosa.display.specshow(librosa.power_to_db(S, ref=np.max), sr=sr, y_axis='mel')
    plt.title("Espectrograma de Mel")
    plt.tight_layout()
    plt.show()

    y_solo_voz = y[np.abs(y) > 0.02]

    if len(y_solo_voz) == 0:
        print(f"Audio {ruta} descartado: No se detecta suficiente nivel de voz.")
        return

    feat = {}

    rms = librosa.feature.rms(y=y_solo_voz)[0]
    feat['rms_mean'] = np.mean(rms)
    feat['rms_std']  = np.std(rms)

    feat['zcr'] = np.mean(librosa.feature.zero_crossing_rate(y)[0])

    f0, _, _ = librosa.pyin(y, fmin=80, fmax=450, sr=sr)
    f0_c = f0[~np.isnan(f0)]
    if len(f0_c) > 0:
        # CORRECCIÓN: Reparado el salto de línea roto que daba SyntaxError
        feat['f0_mean'] = np.mean(f0_c)
        feat['f0_std'] = np.std(f0_c)
        feat['f0_max'] = np.max(f0_c)
    else:
        feat['f0_mean'] = feat['f0_std'] = feat['f0_max'] = 0

    mfccs = librosa.feature.mfcc(y=y, sr=sr, n_mfcc=25)
    delta_mfcc = librosa.feature.delta(mfccs)
    for i in range(25):
        feat[f'mfcc_{i}'] = np.mean(mfccs[i])
        feat[f'delta_{i}'] = np.mean(delta_mfcc[i])

    df = pd.DataFrame([feat])
    
    input_final = df[modelo_ia.feature_names_in_]

    pred = modelo_ia.predict(input_final)
    prob = modelo_ia.predict_proba(input_final)
    emocion = le.inverse_transform(pred)[0]

    print(f"\n[RESULTADO PREDICCIÓN]")
    print(f"Emoción estimada: {emocion.upper()}")
    print(f"Confianza/Probabilidad: {np.max(prob)*100:.2f}%")
    print(f"Métricas clave -> RMS medio: {feat['rms_mean']:.4f} | Tono medio (F0): {feat['f0_mean']:.2f} Hz")
    print("-" * 60)

print("\nAhora, sube los archivos de voz (.wav u .ogg) que quieras analizar:")
audios = files.upload()

for a in audios.keys():
    print(f"\nAnalizando el archivo de voz: {a}")
    examinar_audio(a)
