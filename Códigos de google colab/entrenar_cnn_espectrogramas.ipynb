import os
import numpy as np
from google.colab import drive
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import LabelEncoder
from tensorflow.keras.models import Sequential
# CORRECCIÓN: Importación de todas las capas necesarias para la CNN
from tensorflow.keras.layers import Input, Conv2D, BatchNormalization, MaxPooling2D, Dropout, Flatten, Dense
from tensorflow.keras.optimizers import Adam
from tensorflow.keras.utils import to_categorical
from tensorflow.keras.callbacks import EarlyStopping, ReduceLROnPlateau

if not os.path.exists('/content/drive'):
    drive.mount('/content/drive')

X = np.load('/content/drive/MyDrive/X7_aug.npy')
y = np.load('/content/drive/MyDrive/y7_aug.npy')

le = LabelEncoder()
y_encoded = le.fit_transform(y)

X = (X - np.mean(X, axis=(1,2), keepdims=True)) / np.std(X, axis=(1,2), keepdims=True)

X = X.reshape(X.shape[0], 64, X.shape[2], 1)
y_cat = to_categorical(y_encoded)

X_tr, X_te, y_tr, y_te = train_test_split(
    X, y_cat, test_size=0.15, random_state=42, stratify=y_encoded
)

callback_parada = EarlyStopping(
    monitor='val_loss',
    patience=14,
    restore_best_weights=True,
    verbose=1
)

reductor_lr = ReduceLROnPlateau(
    monitor='val_loss',
    factor=0.5,
    patience=4,
    min_lr=0.00001,
    verbose=1
)

modelo = Sequential([
    Input(shape=(64, X.shape[2], 1)),

    # Bloque Convolucional 1
    Conv2D(32, (3,3), activation='relu', padding='same'),
    BatchNormalization(),
    Conv2D(32, (3,3), activation='relu', padding='same'),
    BatchNormalization(),
    MaxPooling2D(2,2),
    Dropout(0.25),

    # Bloque Convolucional 2
    Conv2D(64, (3,3), activation='relu', padding='same'),
    BatchNormalization(),
    Conv2D(64, (3,3), activation='relu', padding='same'),
    BatchNormalization(),
    MaxPooling2D(2,2),
    Dropout(0.3),

    # Bloque Convolucional 3 de extracción profunda
    Conv2D(128, (3,3), activation='relu', padding='same'),
    BatchNormalization(),
    Flatten(),

    # Bloque de Clasificación (Capas Densas)
    Dense(256, activation='relu'),
    BatchNormalization(),
    Dropout(0.4),
    Dense(len(le.classes_), activation='softmax')
])

modelo.compile(
    optimizer=Adam(0.001), 
    loss='categorical_crossentropy',
    metrics=['accuracy']
)

print("-> Iniciando el entrenamiento de la Red Neuronal Convolucional...")
modelo.fit(
    X_tr, y_tr,
    epochs=100,
    batch_size=64,
    validation_data=(X_te, y_te),
    callbacks=[callback_parada, reductor_lr],
    verbose=1
)

exactitud_cnn = modelo.evaluate(X_te, y_te, verbose=0)[1] * 100

print(f"\nEntrenamiento finalizado de la CNN.")
print(f"Exactitud del modelo en el conjunto de test: {exactitud_cnn:.2f}%")
