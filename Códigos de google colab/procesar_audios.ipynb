import os
import librosa
import numpy as np
import pandas as pd
from google.colab import drive

if not os.path.exists('/content/drive'):
    drive.mount('/content/drive')

ORIGEN = '/content/drive/MyDrive/Audios_Organizados'
OUT_CSV = '/content/drive/MyDrive/v7_aug.csv'
OUT_X = '/content/drive/MyDrive/X7_aug.npy'
OUT_Y = '/content/drive/MyDrive/y7_aug.npy'

SR_FIJO = 44100 
DURACION_SEGUNDOS = 3  
DURACION_FIJA_SAMPLES = DURACION_SEGUNDOS * SR_FIJO 
N_FFT = 1024 

datos_svm, X_espectros, y_labels = [], [], []

emociones = sorted([d for d in os.listdir(ORIGEN) if os.path.isdir(os.path.join(ORIGEN, d))])
mapa = {nombre: i for i, nombre in enumerate(emociones)}

def normalizar_duracion(audio):
    """Ajusta la longitud del audio al tamaño fijo mediante repetición o recorte."""
    if len(audio) < DURACION_FIJA_SAMPLES:
        return np.tile(audio, (DURACION_FIJA_SAMPLES // len(audio)) + 1)[:DURACION_FIJA_SAMPLES]
    return audio[:DURACION_FIJA_SAMPLES]

for emocion in emociones:
    ruta_carpeta = os.path.join(ORIGEN, emocion)
    print(f"-> Procesando: {emocion}...")

    for archivo in os.listdir(ruta_carpeta):
        if not archivo.lower().endswith(('.wav', '.ogg')): 
            continue

        try:
            y_base, sr = librosa.load(os.path.join(ruta_carpeta, archivo), sr=SR_FIJO)
            y_base, _ = librosa.effects.trim(y_base, top_db=30)

            v_orig = librosa.util.normalize(normalizar_duracion(y_base))
            v_ruido = v_orig + 0.005 * np.random.randn(len(v_orig))

            y_fast = librosa.effects.time_stretch(y_base, rate=1.1)
            v_fast = librosa.util.normalize(normalizar_duracion(y_fast))

            y_slow = librosa.effects.time_stretch(y_base, rate=0.9)
            v_slow = librosa.util.normalize(normalizar_duracion(y_slow))

            variantes = [
                (v_orig, "orig"), (v_ruido, "ruido"),
                (v_fast, "fast"), (v_slow, "slow")
            ]

            for v_audio, sufijo in variantes:
                feat = {'archivo': f"{sufijo}_{archivo}", 'emocion': emocion}

                rms = librosa.feature.rms(y=v_audio)[0]
                feat['rms_mean'], feat['rms_std'] = np.mean(rms), np.std(rms)

                feat['zcr'] = np.mean(librosa.feature.zero_crossing_rate(v_audio)[0])

                f0, _, _ = librosa.pyin(v_audio, fmin=100, fmax=500, sr=SR_FIJO)
                f0_c = f0[~np.isnan(f0)]
                if len(f0_c) > 0:
                    feat['f0_mean'] = np.mean(f0_c)
                    feat['f0_std'] = np.std(f0_c)
                    feat['f0_max'] = np.max(f0_c)
                else:
                    feat['f0_mean'] = feat['f0_std'] = feat['f0_max'] = 0

                mfcc = librosa.feature.mfcc(y=v_audio, sr=SR_FIJO, n_mfcc=25)
                delta_mfcc = librosa.feature.delta(mfcc)

                for i in range(25):
                    feat[f'mfcc_{i}'] = np.mean(mfcc[i])
                    feat[f'delta_{i}'] = np.mean(delta_mfcc[i]) 

                datos_svm.append(feat)

                mel = librosa.feature.melspectrogram(y=v_audio, sr=SR_FIJO, n_mels=64)
                mel_db = librosa.power_to_db(mel, ref=np.max)
                X_espectros.append(mel_db)
                y_labels.append(mapa[emocion])

        except Exception as e:
            print(f"Error procesando {archivo}: {e}")
            continue

df_final = pd.DataFrame(datos_svm)
df_final.to_csv(OUT_CSV, index=False)

X_final = np.array(X_espectros)
y_final = np.array(y_labels)

np.save(OUT_X, X_final)
np.save(OUT_Y, y_final)
